    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nfor (const item of items){\n\n if(!item.json.Email.match(/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/)){\n   item.json.reason=\"Invalid Email\";\n }\n\n else if(![\"high\",\"medium\",\"low\"].includes(item.json.Priority)){\n   item.json.reason=\"Invalid Priority\";\n }\n\n else{\n   item.json.reason=\"Unknown Issue Type\";\n }\n\n}\n\nreturn items;"
      },
