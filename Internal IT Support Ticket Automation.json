    },
    {
      "parameters": {
        "jsCode": "const processedItems = $input.all();\n\nconst processed = processedItems.length;\nconst total = processedItems.length > 0 ? processedItems[0].json.total_received : 0;\nconst rejected = total - processed; // simple math — no lookup needed\n\nconst teamCounts = {\n  Network:0,\n  \"IT Support\":0,\n  Applications:0,\n  Infrastructure:0,\n  General:0\n};\n\nfor (const item of processedItems) {\n  const team = item.json.team;\n\n  if(teamCounts[team] !== undefined){\n    teamCounts[team]++;\n  }\n}\n\nconst output = [];\n\noutput.push({ json:{ metric:\"total_received\", value: total } });\noutput.push({ json:{ metric:\"processed\", value: processed } });\noutput.push({ json:{ metric:\"rejected\", value: rejected } });\n\nfor(const team in teamCounts){\n  output.push({\n    json:{\n      metric: team,\n      value: teamCounts[team]\n    }\n  });\n}\n\nreturn output;"
      },
