    {
      "parameters": {
        "jsCode": "const validTypes = [\"wifi\",\"login\",\"software\",\"hardware\"];\n\nfor (const item of $input.all()) {\n\n  let issue = item.json.IssueType?.toString().toLowerCase().trim();\n\n  if(!validTypes.includes(issue)){\n    issue = \"other\";\n  }\n\n  item.json.IssueType = issue;\n\n  item.json.Priority = item.json.Priority?.toString().toLowerCase().trim() || \"low\";\n  item.json.Email = item.json.Email?.toString().toLowerCase().trim() || \"\";\n\n}\n\nreturn $input.all();"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        336,
        -16
      ],
      "id": "854ae1eb-9bba-49f2-9d29-460f81712a1c",
      "name": "Normalize Fields"
    },
    {
      "parameters": {
        "options": {}
