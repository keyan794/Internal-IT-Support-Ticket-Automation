      "typeVersion": 1.1,
      "position": [
        -80,
        -16
      ],
      "id": "2d5fc4f1-f572-4597-b8aa-f18e9a48eb91",
      "name": "Read CSV"
    },
    {
      "parameters": {
        "jsCode": "for (const item of $input.all()) {\n  item.json.ticket_id =\n    \"TICK-\" + Date.now() + \"-\" + Math.floor(Math.random()*1000);\n}\n\nreturn $input.all();"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        960,
        -16
      ],
      "id": "ae6a915b-6987-4842-a5b7-6c9b2ff395ca",
      "name": "Generate Ticket ID"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all().sort(\n (a,b)=> new Date(a.json.Timestamp) - new Date(b.json.Timestamp)\n);\n\nconst seen = new Map();\n\nreturn items.filter(item => {\n\n  const key = `${item.json.Email}_${item.json.IssueType}`;\n  const timestamp = new Date(item.json.Timestamp);\n\n  if(seen.has(key)){\n    const previous = seen.get(key);\n    const diff = (timestamp - previous) / (1000*60*60);\n\n    if(diff <= 24){\n      return false;\n    }\n  }\n\n  seen.set(key,timestamp);\n  return true;\n\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1168,
        -16
      ],
      "id": "e6e14c05-479a-4391-94cc-d6b98f3e0775",
      "name": "Deduplicate Tickets"
    },
    {
      "parameters": {
        "jsCode": "for (const item of $input.all()) {\n\nlet hours = 0;\n\nconst priority = item.json.Priority.toLowerCase();\n\nif (priority === \"high\") hours = 4;\nif (priority === \"medium\") hours = 24;\nif (priority === \"low\") hours = 72;\n\nconst timestamp = new Date(item.json.Timestamp);\n\n// add SLA hours\ntimestamp.setHours(timestamp.getHours() + hours);\n\nitem.json.sla_deadline = timestamp.toLocaleString();\n\n}\n\nreturn $input.all();"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1584,
        -16
      ],
      "id": "e73552b4-a73e-4d58-a4a9-4801fa877d13",
      "name": "SLA Calculation"
    },
    {
