    {
      "parameters": {
        "jsCode": "for (const item of $input.all()) {\n\n  const issue = item.json.IssueType;\n\n  if(issue === \"wifi\"){\n    item.json.team = \"Network\";\n  }\n  else if(issue === \"login\"){\n    item.json.team = \"IT Support\";\n  }\n  else if(issue === \"software\"){\n    item.json.team = \"Applications\";\n  }\n  else if(issue === \"hardware\"){\n    item.json.team = \"Infrastructure\";\n  }\n  else{\n    item.json.team = \"General\";\n  }\n\n}\n\nreturn $input.all();"
      },
